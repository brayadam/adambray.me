---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE } from "../consts";
---

<html lang="en">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description="I write about the systems I build, the infrastructure I run, and the projects I’m working on."
    />
  </head>
  <body>
    <Header />

    <main class="page">
      <section class="hero">
        <h1>I build reliable systems for real life.</h1>
        <p class="intro">
          This is where I document what I’m building, how my homelab is put together,
          and the projects I’m working on along the way.
        </p>
      </section>

      <section class="links-grid">
        <a class="card" href="/writing">
          <h2>Writing</h2>
          <p>
            Posts on homelab design, backups, networking, and the decisions behind
            how I run things.
          </p>
        </a>

        <a class="card" href="/stack">
          <h2>Stack</h2>
          <p>
            A high-level overview of the hardware, services, networking, storage and
            backup strategy behind my setup.
          </p>
        </a>

        <a class="card" href="/projects">
          <h2>Projects</h2>
          <p>
            The things I’m building outside the day-to-day running of the homelab,
            from ideas to active projects.
          </p>
        </a>
      </section>

    </main>

    <Footer />
  </body>
</html>

<style>
  .page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .hero {
    max-width: 760px;
    margin-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.65;
  }

  h1 {
    margin: 0 0 1rem;
    font-size: clamp(2.2rem, 4.2vw, 3.2rem);
    line-height: 1.1;
    max-width: 18ch;
  }

  .intro {
    margin: 0;
    max-width: 60ch;
    font-size: 1.15rem;
    line-height: 1.75;
    opacity: 0.9;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .card {
    display: block;
    padding: 1.5rem;
    border: 1px solid rgba(128, 128, 128, 0.18);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.03);
    color: inherit;
    text-decoration: none;
    transition: transform 0.15s ease, border-color 0.15s ease;
  }

  .card:hover {
    transform: translateY(-2px);
    border-color: rgba(128, 128, 128, 0.3);
  }

  .card h2 {
    margin: 0 0 0.75rem;
    font-size: 1.2rem;
  }

  .card p {
    margin: 0;
    line-height: 1.7;
  }

  .currently {
    max-width: 760px;
    padding-top: 2rem;
    border-top: 1px solid rgba(128, 128, 128, 0.15);
  }

  .currently h2 {
    margin: 0 0 1rem;
    font-size: 1.5rem;
  }

  .currently ul {
    margin: 0;
    padding-left: 1.2rem;
  }

  .currently li {
    line-height: 1.75;
    margin-bottom: 0.5rem;
  }

  @media (max-width: 900px) {
    .links-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 800px) {
    .page {
      padding: 2rem 1.25rem 4rem;
    }

    .intro {
      font-size: 1.05rem;
    }
  }
</style>
