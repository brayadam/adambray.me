---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('writing'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Home</h1>
			<p>
				I build and run a home server stack for my family — storage, backups, media, networking, 
				and self-hosting — and I write down the decisions so future-me doesn’t suffer.
			</p>
			<p>
				This site is a mix of architecture notes, guides, and lessons learned.
			</p>
			<section class="latest">
				<h2>Latest writing</h2>

				{posts.length === 0 ? (
					<p class="muted">No posts yet.</p>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/writing/${post.id}/`}>
									<span class="title">{post.data.title}</span>
									<span class="date">
										<FormattedDate date={post.data.pubDate} />
									</span>
								</a>
							</li>
						))}
					</ul>
				)}

				<p class="more">
					<a href="/writing">View all writing →</a>
				</p>
			</section>

		</main>
		<Footer />
		<style>
			.latest {
				max-width: 65ch;
				margin: 3rem auto 0;
			}

			.latest h2 {
				margin-bottom: 1rem;
			}

			.post-list {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.post-list li {
				margin-bottom: 0.75rem;
			}

			.post-list a {
				display: flex;
				justify-content: space-between;
				gap: 1rem;
				text-decoration: none;
			}

			.post-list .title {
				color: rgb(var(--black));
			}

			.post-list .date {
				color: rgb(var(--gray));
				white-space: nowrap;
			}

			.more {
				margin-top: 1rem;
			}

			.muted {
				color: rgb(var(--gray));
			}
			.latest .more a {
				color: rgb(var(--accent));
				text-decoration: none;
				font-weight: 500;
			}
				.latest .more a:hover {
				text-decoration: underline;
			}

		</style>
	</body>
</html>